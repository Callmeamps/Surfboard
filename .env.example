# Surfboard Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# GitHub OAuth (required for Codespaces)
# Create an OAuth app at: https://github.com/settings/developers
# Required scope: codespace
GITHUB_CLIENT_ID=

# Replit OAuth (optional)
# REPLIT_CLIENT_ID=
# REPLIT_DEVICE_CODE_URL=https://replit.com/api/auth/device/code
# REPLIT_TOKEN_URL=https://replit.com/api/auth/token
# REPLIT_API_BASE=https://replit.com/api
# REPLIT_SCOPE=

# Gitpod OAuth (optional)
# GITPOD_CLIENT_ID=
# GITPOD_DEVICE_CODE_URL=https://gitpod.io/api/oauth/device-code
# GITPOD_TOKEN_URL=https://gitpod.io/api/oauth/token
# GITPOD_API_BASE=https://api.gitpod.io
# GITPOD_SCOPE=
