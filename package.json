{
  "name": "surfboard",
  "version": "0.1.0",
  "description": "A riced Electron-based browser with vertical tabs, sidebar, and AI sidecar",
  "main": "app.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "dev": "electron . --no-sandbox --dev",
    "test": "jest --verbose"
  },
